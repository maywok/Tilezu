#!/bin/sh
# Strip accidental Cursor co-author trailers before a commit is finalized.
MSG_FILE="$1"
if [ -f "$MSG_FILE" ]; then
  grep -v '^Co-authored-by: Cursor <cursoragent@cursor.com>$' "$MSG_FILE" > "$MSG_FILE.tmp" && mv -f "$MSG_FILE.tmp" "$MSG_FILE"
  grep -v '^Made-with: Cursor$' "$MSG_FILE" > "$MSG_FILE.tmp" && mv -f "$MSG_FILE.tmp" "$MSG_FILE"
fi
exit 0